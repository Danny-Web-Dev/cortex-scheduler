    "@prisma/client": "^5.22.0",
    "cookie-parser": "^1.4.7",
    "luxon": "^3.7.2",
    "nestjs-pino": "^4.6.1",
    "nestjs-zod": "^5.4.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.22.0",
