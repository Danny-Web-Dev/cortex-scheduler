{
  "info": {
    "name": "Cortex Scheduler API",
    "description": "End-to-end collection for the Cortex Scheduler API. Run the folders top-to-bottom (Runner or `newman run`) — post-response scripts chain the whole demo: request OTP → verify → browse catalog → get slots → hold → confirm → reschedule → cancel → re-hold → release → list → refresh → logout. No manual copying of tokens or ids required.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api"
    },
    {
      "key": "phone",
      "value": ""
    },
    {
      "key": "devCode",
      "value": ""
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "specialtyId",
      "value": ""
    },
    {
      "key": "doctorId",
      "value": ""
    },
    {
      "key": "slotDate",
      "value": ""
    },
    {
      "key": "slotStartsAt",
      "value": ""
    },
    {
      "key": "rescheduleStartsAt",
      "value": ""
    },
    {
      "key": "reholdStartsAt",
      "value": ""
    },
    {
      "key": "appointmentId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Request OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/otp/request",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "otp",
                "request"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{phone}}\"\n}"
            },
            "auth": {
              "type": "noauth"
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Fresh user per run so the flow always logs in cleanly.",
                  "const phone = '+97250' + Math.floor(1000000 + Math.random() * 8999999);",
                  "pm.collectionVariables.set('phone', phone);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('returns dev code', () => pm.expect(j.devCode).to.be.a('string'));",
                  "pm.collectionVariables.set('devCode', j.devCode);"
                ]
              }
            }
          ]
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/otp/verify",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "otp",
                "verify"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{phone}}\",\n  \"code\": \"{{devCode}}\"\n}"
            },
            "auth": {
              "type": "noauth"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('returns access token', () => pm.expect(j.accessToken).to.be.a('string'));",
                  "pm.collectionVariables.set('accessToken', j.accessToken);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Specialties",
      "item": [
        {
          "name": "List Specialties",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/specialties",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "specialties"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('has specialties', () => pm.expect(j.length).to.be.above(0));",
                  "pm.collectionVariables.set('specialtyId', j[0].id);"
                ]
              }
            }
          ]
        },
        {
          "name": "List Doctors in Specialty",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/specialties/{{specialtyId}}/doctors",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "specialties",
                "{{specialtyId}}",
                "doctors"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('has doctors', () => pm.expect(j.length).to.be.above(0));",
                  "pm.collectionVariables.set('doctorId', j[0].id);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Doctors",
      "item": [
        {
          "name": "Get Slots",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/doctors/{{doctorId}}/slots?date={{slotDate}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "doctors",
                "{{doctorId}}",
                "slots"
              ],
              "query": [
                {
                  "key": "date",
                  "value": "{{slotDate}}"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Next Monday (a seeded availability weekday) in YYYY-MM-DD.",
                  "const d = new Date();",
                  "const add = ((8 - d.getUTCDay()) % 7) || 7;",
                  "d.setUTCDate(d.getUTCDate() + add);",
                  "pm.collectionVariables.set('slotDate', d.toISOString().slice(0, 10));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('has at least 3 free slots', () => pm.expect(j.slots.length).to.be.above(2));",
                  "pm.collectionVariables.set('slotStartsAt', j.slots[0].startsAt);",
                  "pm.collectionVariables.set('rescheduleStartsAt', j.slots[1].startsAt);",
                  "pm.collectionVariables.set('reholdStartsAt', j.slots[2].startsAt);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Appointments",
      "item": [
        {
          "name": "Hold Slot",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/appointments/hold",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "appointments",
                "hold"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"doctorId\": \"{{doctorId}}\",\n  \"startsAt\": \"{{slotStartsAt}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "const j = pm.response.json();",
                  "pm.test('status HELD', () => pm.expect(j.status).to.eql('HELD'));",
                  "pm.collectionVariables.set('appointmentId', j.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Confirm Hold",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/appointments/{{appointmentId}}/confirm",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "appointments",
                "{{appointmentId}}",
                "confirm"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('status CONFIRMED', () => pm.expect(j.status).to.eql('CONFIRMED'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Reschedule",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/appointments/{{appointmentId}}/reschedule",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "appointments",
                "{{appointmentId}}",
                "reschedule"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"startsAt\": \"{{rescheduleStartsAt}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('rescheduled + confirmed', () => pm.expect(j.status).to.eql('CONFIRMED'));",
                  "// reschedule creates a new appointment atomically; track the new id.",
                  "pm.collectionVariables.set('appointmentId', j.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Cancel",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/appointments/{{appointmentId}}/cancel",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "appointments",
                "{{appointmentId}}",
                "cancel"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('status CANCELLED', () => pm.expect(j.status).to.eql('CANCELLED'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Hold Slot (for release demo)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/appointments/hold",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "appointments",
                "hold"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"doctorId\": \"{{doctorId}}\",\n  \"startsAt\": \"{{reholdStartsAt}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "const j = pm.response.json();",
                  "pm.collectionVariables.set('appointmentId', j.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Release Hold",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/appointments/{{appointmentId}}/hold",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "appointments",
                "{{appointmentId}}",
                "hold"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('204 No Content', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Me",
      "item": [
        {
          "name": "My Appointments (upcoming)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/me/appointments?scope=upcoming",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "me",
                "appointments"
              ],
              "query": [
                {
                  "key": "scope",
                  "value": "upcoming"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('is an array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "My Appointments (past)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/me/appointments?scope=past",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "me",
                "appointments"
              ],
              "query": [
                {
                  "key": "scope",
                  "value": "past"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('is an array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            },
            "auth": {
              "type": "noauth"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('status ok', () => pm.expect(pm.response.json().status).to.eql('ok'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Session",
      "item": [
        {
          "name": "Refresh Tokens",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "refresh"
              ]
            },
            "auth": {
              "type": "noauth"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('rotates access token', () => pm.expect(j.accessToken).to.be.a('string'));",
                  "pm.collectionVariables.set('accessToken', j.accessToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "logout"
              ]
            },
            "auth": {
              "type": "noauth"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('204 No Content', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
