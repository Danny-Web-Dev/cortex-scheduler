# --- API ---
NODE_ENV=development
PORT=3000
JWT_SECRET=change-me-in-production
CLINIC_TZ=Asia/Jerusalem

# --- Database (docker-compose MySQL) ---
MYSQL_ROOT_PASSWORD=cortex_dev_root
MYSQL_DATABASE=cortex
MYSQL_PORT=3306
DATABASE_URL="mysql://root:cortex_dev_root@localhost:3306/cortex"

# --- docker-compose host port mapping (api/web containers only; the api
# container's own DATABASE_URL is computed in docker-compose.yml, not read
# from the line above, since it must point at the mysql service, not localhost) ---
API_PORT=3000
WEB_PORT=8080
